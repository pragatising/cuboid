{
  "name": "@sragatiping/cuboid",
  "version": "0.1.6",
  "description": "Cube — React components and design tokens for data views, tables, and themed UI.",
  "keywords": [
    "react",
    "cube",
    "design-system",
    "json",
    "table",
    "visualization",
    "tokens"
  ],
  "license": "MIT",
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./tokens": {
      "import": "./dist/tokens.es.js",
      "require": "./dist/tokens.cjs.js",
      "types": "./dist/tokens.d.ts"
    },
    "./style.css": "./dist/style.css",
    "./theme.css": "./src/theme/output/theme.css",
    "./components.css": "./src/theme/output/components.css",
    "./token-output.json": "./src/theme/output/token-output.json"
  },
  "files": [
    "dist",
    "src/theme/output/theme.css",
    "src/theme/output/components.css",
    "src/theme/output/token-output.json"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "check:icons": "node scripts/check-icon-imports.mjs",
    "icons:extract": "node scripts/extract-figma-icons.mjs",
    "icons:sync": "node scripts/sync-icons.mjs",
    "icons": "npm run icons:extract && npm run icons:sync && npm run check:icons",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "tokens:functional-colors": "node scripts/flatten-functional-colors.mjs",
    "tokens:functional-typography": "node scripts/flatten-functional-typography.mjs",
    "tokens:typography-theme": "node scripts/build-typography-theme.mjs",
    "pretokens:theme": "node scripts/build-typography-theme.mjs",
    "tokens:theme": "node scripts/build-theme.mjs && node scripts/build-theme-css.mjs && node scripts/build-component-theme-css.mjs",
    "prebuild": "npm run tokens:theme"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-interactions": "^8.6.18",
    "@storybook/addon-onboarding": "^8.6.18",
    "@storybook/blocks": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "storybook": "^8.6.18",
    "typescript": "^5.5.3",
    "vite": "^5.4.1",
    "vite-plugin-dts": "^4.0.2"
  },
  "dependencies": {
    "@material-symbols-svg/react": "^0.9.0",
    "@tanstack/react-table": "^8.21.3"
  }
}
