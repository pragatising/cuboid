{
  "borderInset": {
    "thin": {
      "value": "inset 0 0 0 {borderWidth.thin}"
    },
    "thick": {
      "value": "inset 0 0 0 {borderWidth.thick}"
    },
    "thicker": {
      "value": "inset 0 0 0 {borderWidth.thicker}"
    }
  },
  "borderWidth": {
    "thin": {
      "value": "max(1px, 0.0625rem)"
    },
    "thick": {
      "value": "max(2px, 0.125rem)"
    },
    "thicker": {
      "value": "max(4px, 0.25rem)"
    }
  },
  "borderRadius": {
    "small": {
      "value": "{size.space.4}"
    },
    "medium": {
      "value": "{size.space.8}"
    },
    "large": {
      "value": "{size.space.16}"
    },
    "xlarge": {
      "value": "{size.space.24}"
    },
    "full": {
      "value": "9999px"
    }
  }
}

